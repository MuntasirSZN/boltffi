assertion_line: 1278
expression: "render_class(&cls, \"boltffi\")"
---
public final class Connection {
    let handle: UnsafeMutableRawPointer

    init(handle: UnsafeMutableRawPointer) {
        self.handle = handle
    }

    public init(url: String) throws {
        var url = url
        let ptr = url.withUTF8 { urlBuf -> UnsafeMutableRawPointer? in boltffi_connection_open(urlBuf.baseAddress!, UInt(urlBuf.count)) }
        guard let ptr = ptr else {
            throw FfiError(message: takeLastErrorMessage())
        }
        self.handle = ptr
    }

    deinit {
        boltffi_connection_free(handle)
    }

}
