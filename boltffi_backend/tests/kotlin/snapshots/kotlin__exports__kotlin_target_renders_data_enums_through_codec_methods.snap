package com.boltffi.demo
@Suppress("FunctionName")
private object Native {
    @JvmStatic external fun boltffi_function_demo_echo_bytes(bytes: ByteArray): ByteArray?
    @JvmStatic external fun boltffi_function_demo_keep_person(person: ByteArray): ByteArray?
    @JvmStatic external fun boltffi_function_demo_keep_shape(shape: ByteArray): ByteArray?
    @JvmStatic external fun boltffi_function_demo_echo_message(message: ByteArray): ByteArray?
}


data class Person(
    val name: String
) {
    internal fun wireSize(): Int {
        return 4 + Utf8Codec.maxBytes(this.name)
    }

    internal fun writeTo(writer: WireWriter) {
        writer.writeString(this.name)
    }

    internal fun toByteArray(): ByteArray {
        val buffer = WireWriterPool.acquire(wireSize())
        val writer = buffer.writer
        try {
            writeTo(writer)
            return buffer.bytes()
        } finally {
            buffer.close()
        }
    }

    companion object {
        internal fun fromReader(reader: WireReader): Person {
            return Person(
                reader.readString()
            )
        }

        internal fun fromByteArray(bytes: ByteArray): Person {
            val reader = WireReader(bytes)
            return fromReader(reader)
        }
    }
}


sealed class Shape {
    internal abstract fun wireSize(): Int

    internal abstract fun writeTo(writer: WireWriter)

    internal fun toByteArray(): ByteArray {
        val buffer = WireWriterPool.acquire(wireSize())
        val writer = buffer.writer
        try {
            writeTo(writer)
            return buffer.bytes()
        } finally {
            buffer.close()
        }
    }

    data class Label(
        val field0: String
    ) : Shape() {
        internal override fun wireSize(): Int {
            return 4 + 4 + Utf8Codec.maxBytes(this.field0)
        }

        internal override fun writeTo(writer: WireWriter) {
            writer.writeU32(0.toUInt())
            writer.writeString(this.field0)
        }
    }

    companion object {
        internal fun fromReader(reader: WireReader): Shape {
            val tag = reader.readU32()
            return when (tag) {
                0.toUInt() -> Label(reader.readString())
                else -> throw IllegalArgumentException("unknown Shape tag: $tag")
            }
        }

        internal fun fromByteArray(bytes: ByteArray): Shape {
            val reader = WireReader(bytes)
            return fromReader(reader)
        }
    }
}


sealed class Message {
    internal abstract fun wireSize(): Int

    internal abstract fun writeTo(writer: WireWriter)

    internal fun toByteArray(): ByteArray {
        val buffer = WireWriterPool.acquire(wireSize())
        val writer = buffer.writer
        try {
            writeTo(writer)
            return buffer.bytes()
        } finally {
            buffer.close()
        }
    }

    object Empty : Message() {
        internal override fun wireSize(): Int {
            return 4
        }

        internal override fun writeTo(writer: WireWriter) {
            writer.writeU32(0.toUInt())
        }
    }
    data class Text(
        val field0: String
    ) : Message() {
        internal override fun wireSize(): Int {
            return 4 + 4 + Utf8Codec.maxBytes(this.field0)
        }

        internal override fun writeTo(writer: WireWriter) {
            writer.writeU32(1.toUInt())
            writer.writeString(this.field0)
        }
    }
    data class Named(
        val name: String
    ) : Message() {
        internal override fun wireSize(): Int {
            return 4 + 4 + Utf8Codec.maxBytes(this.name)
        }

        internal override fun writeTo(writer: WireWriter) {
            writer.writeU32(2.toUInt())
            writer.writeString(this.name)
        }
    }

    companion object {
        internal fun fromReader(reader: WireReader): Message {
            val tag = reader.readU32()
            return when (tag) {
                0.toUInt() -> Empty
                1.toUInt() -> Text(reader.readString())
                2.toUInt() -> Named(reader.readString())
                else -> throw IllegalArgumentException("unknown Message tag: $tag")
            }
        }

        internal fun fromByteArray(bytes: ByteArray): Message {
            val reader = WireReader(bytes)
            return fromReader(reader)
        }
    }
}

fun echoBytes(bytes: ByteArray): ByteArray {
    val __boltffi_bytes_wire = WireWriterPool.acquire(4 + bytes.size)
    val __boltffi_bytes_writer = __boltffi_bytes_wire.writer
    __boltffi_bytes_writer.writeBytes(bytes)
    try {
        val __boltffi_result = Native.boltffi_function_demo_echo_bytes(__boltffi_bytes_wire.bytes()) ?: throw IllegalStateException("null buffer returned")
        val __boltffi_reader = WireReader(__boltffi_result)
        return __boltffi_reader.readBytes()
    } finally {
        __boltffi_bytes_wire.close()
    }
}

