data class Point(
    val x: Int,
    val y: Int
) {
    internal fun toByteArray(): ByteArray {
        val buffer = java.nio.ByteBuffer
            .allocate(STRUCT_SIZE)
            .order(java.nio.ByteOrder.nativeOrder())
        writeTo(buffer, 0)
        return buffer.array()
    }

    internal fun toDirectBuffer(): java.nio.ByteBuffer {
        val buffer = java.nio.ByteBuffer
            .allocateDirect(STRUCT_SIZE)
            .order(java.nio.ByteOrder.nativeOrder())
        writeTo(buffer, 0)
        return buffer
    }

    internal fun writeTo(buffer: java.nio.ByteBuffer, offset: Int) {
        buffer.putInt(offset, x)
        buffer.putInt(offset + 4, y)
    }

    companion object {
        internal const val STRUCT_SIZE: Int = 8

        internal fun fromByteArray(bytes: ByteArray): Point {
            require(bytes.size == STRUCT_SIZE)
            val buffer = java.nio.ByteBuffer
                .wrap(bytes)
                .order(java.nio.ByteOrder.nativeOrder())
            return fromBuffer(buffer, 0)
        }

        internal fun fromBuffer(buffer: java.nio.ByteBuffer, offset: Int): Point {
            return Point(
                buffer.getInt(offset),
                buffer.getInt(offset + 4)
            )
        }
    }
}


sealed class SaveError(val value: Int) : Exception() {
    object Failed : SaveError(0)

    companion object {
        fun fromValue(value: Int): SaveError =
            when (value) {
                0 -> Failed
                else -> throw IllegalArgumentException("unknown SaveError value: $value")
            }
    }
}

suspend fun refresh() {
    boltffiCallAsync(
        createFuture = {
            Native.boltffi_function_demo_refresh()
        },
        poll = { future, contHandle -> Native.boltffi_async_function_demo_refresh_poll(future, contHandle) },
        complete = { future ->
            Native.boltffi_async_function_demo_refresh_complete(future)
        },
        free = { future -> Native.boltffi_async_function_demo_refresh_free(future) },
        cancel = { future -> Native.boltffi_async_function_demo_refresh_cancel(future) },
    )
}

suspend fun loadName(): String {
    return boltffiCallAsync(
        createFuture = {
            Native.boltffi_function_demo_load_name()
        },
        poll = { future, contHandle -> Native.boltffi_async_function_demo_load_name_poll(future, contHandle) },
        complete = { future ->
            val __boltffi_result = Native.boltffi_async_function_demo_load_name_complete(future) ?: throw IllegalStateException("null buffer returned")
            val __boltffi_reader = WireReader(__boltffi_result)
            __boltffi_reader.readString()
        },
        free = { future -> Native.boltffi_async_function_demo_load_name_free(future) },
        cancel = { future -> Native.boltffi_async_function_demo_load_name_cancel(future) },
    )
}

suspend fun loadPoint(): Point {
    return boltffiCallAsync(
        createFuture = {
            Native.boltffi_function_demo_load_point()
        },
        poll = { future, contHandle -> Native.boltffi_async_function_demo_load_point_poll(future, contHandle) },
        complete = { future ->
            val __boltffi_result = Native.boltffi_async_function_demo_load_point_complete(future) ?: throw IllegalStateException("null buffer returned")
            Point.fromByteArray(__boltffi_result)
        },
        free = { future -> Native.boltffi_async_function_demo_load_point_free(future) },
        cancel = { future -> Native.boltffi_async_function_demo_load_point_cancel(future) },
    )
}

suspend fun save() {
    boltffiCallAsync(
        createFuture = {
            Native.boltffi_function_demo_save()
        },
        poll = { future, contHandle -> Native.boltffi_async_function_demo_save_poll(future, contHandle) },
        complete = { future ->
            try { Native.boltffi_async_function_demo_save_complete(future) } catch (__boltffi_error: BoltFfiErrorBufferException) { run { val __boltffi_error_reader = WireReader(__boltffi_error.bytes); throw SaveError.fromValue(__boltffi_error_reader.readI32()) } }
        },
        free = { future -> Native.boltffi_async_function_demo_save_free(future) },
        cancel = { future -> Native.boltffi_async_function_demo_save_cancel(future) },
    )
}

