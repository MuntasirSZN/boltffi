}

public enum Shape: Hashable, Equatable, Sendable {
    case label(String)

    @inlinable static func decode(from reader: inout WireReader) -> Shape {
        let tag = reader.readU32()
        switch tag {
        case 0:
            return .label(reader.readString())
        default:
            fatalError("Invalid Shape tag: \(tag)")
        }
    }

    @inlinable func encode(to writer: inout WireWriter) {
        switch self {
        case let .label(field0):
            writer.writeU32(0)
            writer.writeString(field0)
        }
    }
}

public enum Message: Hashable, Equatable, Sendable {
    case empty
    case text(String)
    case named(name: String)

    @inlinable static func decode(from reader: inout WireReader) -> Message {
        let tag = reader.readU32()
        switch tag {
        case 0:
            return .empty
        case 1:
            return .text(reader.readString())
        case 2:
            return .named(name: reader.readString())
        default:
            fatalError("Invalid Message tag: \(tag)")
        }
    }

    @inlinable func encode(to writer: inout WireWriter) {
        switch self {
        case .empty:
            writer.writeU32(0)
        case let .text(field0):
            writer.writeU32(1)
            writer.writeString(field0)
        case let .named(name):
            writer.writeU32(2)
            writer.writeString(name)
        }
    }
}

