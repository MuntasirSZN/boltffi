public struct Person: Hashable, Equatable, Sendable {
    public var name: String

    public init(name: String) {
        self.name = name
    }

    @inlinable static func decode(from reader: inout WireReader) -> Person {
        Person(name: reader.readString())
    }

    @inlinable func encode(to writer: inout WireWriter) {
        writer.writeString(self.name)
