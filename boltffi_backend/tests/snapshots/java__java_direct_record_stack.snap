===== Demo.java =====
package com.boltffi.demo;

final class Native {
    static {
        String virtualMachineName = System.getProperty("java.vm.name", "")
            .toLowerCase(java.util.Locale.ROOT);
        boolean androidRuntime = virtualMachineName.contains("dalvik")
            || virtualMachineName.contains("art");
        if (androidRuntime) {
            System.loadLibrary("boltffi");
        }
    }

    private Native() {}

    static native byte[] boltffi_function_demo_echo_point(java.nio.ByteBuffer point);
}

public final class Demo {
    private Demo() {}

    public static Point echoPoint(Point point) {
        return Point.fromByteArray(Native.boltffi_function_demo_echo_point(point.toDirectBuffer()));
    }
}
===== Point.java =====
package com.boltffi.demo;

public final class Point {
    public final double x;
    public final double y;
    public final boolean visible;
    public final int color;

    public Point(double x, double y, boolean visible, int color) {
        this.x = x;
        this.y = y;
        this.visible = visible;
        this.color = color;
    }


    public double x() {
        return x;
    }

    public double y() {
        return y;
    }

    public boolean visible() {
        return visible;
    }

    public int color() {
        return color;
    }


    @Override
    public boolean equals(Object value) {
        if (this == value) return true;
        if (value == null || getClass() != value.getClass()) return false;
        Point other = (Point) value;
        return Double.compare(this.x, other.x) == 0 && Double.compare(this.y, other.y) == 0 && this.visible == other.visible && this.color == other.color;
    }

    @Override
    public int hashCode() {
        int result = 1;
        result = 31 * result + Double.hashCode(this.x);
        result = 31 * result + Double.hashCode(this.y);
        result = 31 * result + Boolean.hashCode(this.visible);
        result = 31 * result + Integer.hashCode(this.color);
        return result;
    }

    @Override
    public String toString() {
        return "Point{" +
            "x=" + x +
            ", y=" + y +
            ", visible=" + visible +
            ", color=" + color
            + '}';
    }


    static final int STRUCT_SIZE = 24;

    byte[] toByteArray() {
        byte[] bytes = new byte[STRUCT_SIZE];
        writeToDirectBuffer(
            java.nio.ByteBuffer.wrap(bytes).order(java.nio.ByteOrder.nativeOrder()),
            0
        );
        return bytes;
    }


    java.nio.ByteBuffer toDirectBuffer() {
        java.nio.ByteBuffer buffer = java.nio.ByteBuffer
            .allocateDirect(STRUCT_SIZE)
            .order(java.nio.ByteOrder.nativeOrder());
        writeToDirectBuffer(buffer, 0);
        return buffer;
    }

    void writeToDirectBuffer(java.nio.ByteBuffer buffer, int offset) {
        buffer.putDouble((offset + 0), this.x);
        buffer.putDouble((offset + 8), this.y);
        buffer.put((offset + 16), (byte) ((this.visible ? 1 : 0)));
        buffer.putInt((offset + 20), this.color);
    }

    static Point fromDirectBuffer(java.nio.ByteBuffer buffer, int offset) {
        return new Point(buffer.getDouble((offset + 0)), buffer.getDouble((offset + 8)), buffer.get((offset + 16)) != 0, buffer.getInt((offset + 20)));
    }

    static Point fromByteArray(byte[] bytes) {
        if (bytes.length != STRUCT_SIZE) {
            throw new IllegalArgumentException("invalid Point byte size");
        }
        java.nio.ByteBuffer buffer = java.nio.ByteBuffer
            .wrap(bytes)
            .order(java.nio.ByteOrder.nativeOrder());
        return fromDirectBuffer(buffer);
    }

    static Point fromDirectBuffer(java.nio.ByteBuffer buffer) {
        return fromDirectBuffer(buffer, 0);
    }
}
