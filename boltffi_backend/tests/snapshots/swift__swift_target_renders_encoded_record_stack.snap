public struct User: Hashable, Equatable, Sendable {
    public var name: String
    public var age: UInt32
    public var role: Role
    public var nickname: String?
    public var tags: [String]

    public init(
        name: String,
        age: UInt32,
        role: Role,
        nickname: String?,
        tags: [String]
    ) {
        self.name = name
        self.age = age
        self.role = role
        self.nickname = nickname
        self.tags = tags
    }

    @inlinable static func decode(from reader: inout WireReader) -> User {
        User(
            name: reader.readString(),
            age: reader.readU32(),
            role: Role(rawValue: reader.readU8())!,
            nickname: reader.readOptional { reader in reader.readString() },
            tags: reader.readArray { reader in reader.readString() }
        )
    }

    @inlinable func encode(to writer: inout WireWriter) {
        writer.writeString(self.name)
        writer.writeU32(self.age)
        writer.writeU8(self.role.rawValue)
        writer.writeOptional(self.nickname) { writer, boltffiValue0 in writer.writeString(boltffiValue0) }
        writer.writeArray(self.tags) { writer, boltffiValue0 in writer.writeString(boltffiValue0) }
    }
}

public enum Role: UInt8, Hashable, Sendable, CaseIterable {
    case admin = 1
    case guest = 2

    @usableFromInline init(fromC c: UInt8) {
        self = Role(rawValue: c)!
    }

    @usableFromInline var cValue: UInt8 {
        rawValue
    }
}

public func echoUser(user: User) -> User {
    let boltffiUserBytes = boltffiEncode { boltffiUserWriter in user.encode(to: &boltffiUserWriter) }
    return boltffiUserBytes.withUnsafeBufferPointer { boltffiUserBuffer in
        let boltffiResult = boltffi_function_demo_echo_user(boltffiUserBuffer.baseAddress!, UInt(boltffiUserBuffer.count))
        defer { boltffi_free_buf(boltffiResult) }
        return boltffiDecodeOwnedBuf(boltffiResult.ptr, Int(boltffiResult.len)) { boltffiReader in User.decode(from: &boltffiReader) }
    }
}
