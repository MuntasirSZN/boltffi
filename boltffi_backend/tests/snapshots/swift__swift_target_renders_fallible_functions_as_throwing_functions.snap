        defer { boltffi_free_buf(__boltffi_error) }
        throw boltffiDecodeOwnedBuf(__boltffi_error.ptr, Int(__boltffi_error.len)) { __boltffi_error_reader in MathError(rawValue: __boltffi_error_reader.readI32())! }
    }
    return __boltffi_result
}

public func parsePoint(text: String) throws -> Point {
    let __boltffi_text_bytes = boltffiEncode { __boltffi_text_writer in __boltffi_text_writer.writeString(text) }
