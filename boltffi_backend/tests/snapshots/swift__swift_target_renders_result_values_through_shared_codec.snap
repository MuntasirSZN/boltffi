        let boltffiResult = boltffi_function_demo_result_to_string(boltffiValueBuffer.baseAddress!, UInt(boltffiValueBuffer.count))
        defer { boltffi_free_buf(boltffiResult) }
        return boltffiDecodeOwnedBuf(boltffiResult.ptr, Int(boltffiResult.len)) { boltffiReader in boltffiReader.readString() }
    }
}

public func echoResponse(response: Response) -> Response {
    let boltffiResponseBytes = boltffiEncode { boltffiResponseWriter in response.encode(to: &boltffiResponseWriter) }
    return boltffiResponseBytes.withUnsafeBufferPointer { boltffiResponseBuffer in
        let boltffiResult = boltffi_function_demo_echo_response(boltffiResponseBuffer.baseAddress!, UInt(boltffiResponseBuffer.count))
