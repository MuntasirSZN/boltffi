    @inlinable func encode(to writer: inout WireWriter) {
        writer.writeResult(self.result, { writer, boltffiValue0 in writer.writeI32(boltffiValue0) }, { writer, boltffiValue0 in writer.writeString(boltffiValue0.message) })
