    boltffi_jni_exit(env, attached);
    return;
__boltffi_fail:

    boltffi_jni_clear_exception(env);
    boltffi_jni_exit(env, attached);

    complete(complete_context, (FfiStatus){.code = 1}, (FfiBuf_u8){0});

